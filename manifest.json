{
  "manifest_version": 3,
  "name": "Gemini Live Assistant",
  "version": "1.0",
  "description": "Multimodal Live AI Assistant powered by Gemini 2.0",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "microphone",
    "scripting",
    "tabs"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Gemini Live"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/mediapipe/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
